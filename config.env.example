# config.env — proxy runtime configuration
# Copy this file to config.env and fill in your values:
#   cp config.env.example config.env
#
# config.env is gitignored and will never be committed.
# This example file is safe to commit to a public repository.


# =============================================================================
# Dante SOCKS5 server (your US proxy)
# =============================================================================

# IP address of your Dante SOCKS5 server.
# This should be reachable over your WireGuard tunnel.
# If using WireGuard with a /24 subnet, this is typically your peer's tunnel IP.
# Also hardcoded in: redsocks/redsocks.conf, dante/sockd.conf
DANTE_IP="${DANTE_IP:-YOUR_DANTE_IP}"

# TCP port Dante listens on.
# Default is 1080 (standard SOCKS5 port). Change only if your Dante config differs.
# Example: 1080
# Also hardcoded in: redsocks/redsocks.conf, dante/sockd.conf
DANTE_PORT="${DANTE_PORT:-1080}"


# =============================================================================
# redsocks transparent proxy (local listener)
# =============================================================================

# Local address redsocks binds to. Use 127.0.0.1 (loopback) — do not expose this.
# Also hardcoded in: redsocks/redsocks.conf
REDHOST="${REDHOST:-127.0.0.1}"

# Local port redsocks listens on. iptables redirects matched TCP traffic here.
# Pick any unused high port. Default: 12345
# Also hardcoded in: redsocks/redsocks.conf
REDPORT="${REDPORT:-12345}"


# =============================================================================
# dnsmasq DNS listener addresses
# =============================================================================

# Loopback IP dnsmasq binds to on the host. No interface alias needed —
# any address in 127.0.0.0/8 works as a loopback.
# The host's resolvectl DNS for your WiFi interface will be pointed here.
# Example: 127.100.53.53
# Also hardcoded in: dnsmasq/dnsmasq.conf
DNSIP_LOOP="${DNSIP_LOOP:-127.100.53.53}"

# Docker bridge IP. dnsmasq also listens here so containers can resolve DNS.
# Default Docker bridge is 172.17.0.1 — change only if you've customized Docker networking.
# Also hardcoded in: dnsmasq/dnsmasq.conf
DNSIP_BRIDGE="${DNSIP_BRIDGE:-172.17.0.1}"


# =============================================================================
# Network interface
# =============================================================================

# Name of your WiFi (or primary outbound) interface.
# Run `ip link` to find yours. Common values: wlo1, wlan0, wlp3s0, en0 (macOS)
# Example: wlo1
IFACE="${IFACE:-YOUR_WIFI_INTERFACE}"


# =============================================================================
# Kernel ipset names
# =============================================================================
# Names for the kernel ipsets created at startup.
# proxy-on.sh generates dnsmasq/dnsmasq.d/ipsets.conf from these names and the
# DOMAINS_* lists below — you do not need to edit dnsmasq/dnsmasq.conf manually.
# These names can be anything valid as a kernel ipset name (alphanumeric + _).
#
# IMPORTANT: The suffix of IPSET_V4_* / IPSET_V6_* must match the suffix of the
# corresponding DOMAINS_* variable. proxy-on.sh auto-discovers groups by this
# convention — DOMAINS_FOO pairs with IPSET_V4_FOO and IPSET_V6_FOO.

IPSET_V4_NFX="${IPSET_V4_NFX:-netflix_us}"     # Netflix IPv4 ipset
IPSET_V6_NFX="${IPSET_V6_NFX:-netflix_us6}"    # Netflix IPv6 ipset (for REJECT rules)
IPSET_V4_SORA="${IPSET_V4_SORA:-openai_us}"    # OpenAI/ChatGPT IPv4 ipset
IPSET_V6_SORA="${IPSET_V6_SORA:-openai_us6}"   # OpenAI/ChatGPT IPv6 ipset
IPSET_V4_XF="${IPSET_V4_XF:-xfinity_us}"       # Xfinity/Comcast IPv4 ipset
IPSET_V6_XF="${IPSET_V6_XF:-xfinity_us6}"      # Xfinity/Comcast IPv6 ipset


# =============================================================================
# Feature flags
# =============================================================================

# Add targeted ip6tables REJECT rules for steered services.
# This forces IPv4 fallback so traffic goes through redsocks.
# Set to 0 only if you have no IPv6 connectivity and want to skip v6 rules.
USE_IPV6="${USE_IPV6:-1}"

# Block UDP/443 (QUIC) to steered service IPs.
# Streaming services will use QUIC if available, bypassing the TCP-only redsocks.
# Keep true unless you have a QUIC-capable proxy setup.
BLOCK_QUIC="${BLOCK_QUIC:-true}"

# Point the WiFi interface DNS to local dnsmasq when proxy starts.
# Required for ipset population to work. Disable only for testing.
SELF_DNS="${SELF_DNS:-true}"

# Restore firewall baseline (saved on first proxy-on) when proxy turns off.
# If false, iptables rules accumulate — not recommended.
RESTORE_ON_OFF="${RESTORE_ON_OFF:-true}"


# =============================================================================
# Paths
# =============================================================================

# Where firewall snapshots are saved (write-once on first proxy-on).
# To re-save after changing your normal firewall, see README.md § Managing the firewall baseline.
BASELINE_DIR="${BASELINE_DIR:-$HOME/.proxy-firewall-baseline}"

# Path to the dnsmasq docker-compose directory.
# The scripts auto-detect this relative to the repo root — only set this if
# your dnsmasq directory is somewhere non-standard.
DNSMASQ_DIR="${DNSMASQ_DIR:-$HOME/proxy/dnsmasq}"

# Path to the redsocks docker-compose directory.
# Same auto-detection applies — only override if needed.
REDSOCKS_DIR="${REDSOCKS_DIR:-$HOME/proxy/redsocks}"


# =============================================================================
# DNS priming
# =============================================================================

# How many times to retry DNS priming at startup before giving up.
# Each try sends A + AAAA queries for all domains below to dnsmasq.
PRIME_TRIES="${PRIME_TRIES:-6}"

# Domain lists for each service group.
# Used for two things:
#   1. Generating ipset= tagging rules in dnsmasq/dnsmasq.d/ipsets.conf at startup
#   2. DNS priming — dig queries sent to dnsmasq to pre-populate ipsets before
#      iptables rules go in (so the first connection is already steered)
# Space-separated. Add subdomains explicitly if needed (e.g. cdn.myservice.com).
DOMAINS_NFX="${DOMAINS_NFX:-myservice.example.com cdn.myservice.example.com}"
DOMAINS_SORA="${DOMAINS_SORA:-ai.example.com api.ai.example.com}"
DOMAINS_XF="${DOMAINS_XF:-portal.example.com mail.portal.example.com}"

# To add a new service group, append a matching trio below (suffix must match):
#
# DOMAINS_FOO="${DOMAINS_FOO:-example.com api.example.com}"
# IPSET_V4_FOO="${IPSET_V4_FOO:-foo_us}"
# IPSET_V6_FOO="${IPSET_V6_FOO:-foo_us6}"
#
# That's all — no script changes needed.
